# Runtime / storage
HOST_BIND_IP=127.0.0.1
HEALTHCHECK_INTERVAL=120s
# Steady-state healthcheck interval for long-running containers.
# During startup, services can optionally use HEALTHCHECK_INTERVAL_BOOT via start_interval.
HEALTHCHECK_INTERVAL_BOOT=3s
OLLAMA_DATA_DIR=./.state/ollama_data
KEYS_LOCAL_FILE=./.state/keys/keys.local.json
DEV_IMAGE_NAME=course-llm-dev:v1
DEV_JUPYTER_PORT=8888
# JupyterLab token (host browser). Set a strong local secret; passed to the dev container as JUPYTER_TOKEN.
JUPYTER_TOKEN=change_me
DEV_STREAMLIT_PORT=8501
CERT_HOSTS=localhost 127.0.0.1 ::1 caddy litellm phoenix ollama postgres dev

# Postgres (shared server, separate identities per app)
POSTGRES_PORT=5432
POSTGRES_LITELLM_DB=litellm
POSTGRES_LITELLM_USER=litellm
POSTGRES_LITELLM_PASSWORD=change_me
POSTGRES_PHOENIX_DB=phoenix
POSTGRES_PHOENIX_USER=phoenix
POSTGRES_PHOENIX_PASSWORD=change_me
POSTGRES_TOOLBERT_DB=toolbert
POSTGRES_TOOLBERT_USER=toolbert
POSTGRES_TOOLBERT_PASSWORD=change_me
DATABASE_URL=postgresql://${POSTGRES_LITELLM_USER}:${POSTGRES_LITELLM_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_LITELLM_DB}

# LiteLLM proxy / UI
LITELLM_PLATFORM=linux/amd64
# Public TLS endpoint (Caddy)
LITELLM_PORT=4000
LITELLM_CHAOS_PORT=4001
# Internal LiteLLM app port (Docker network only)
LITELLM_INTERNAL_PORT=4000
LITELLM_DEFAULT_TIMEOUT=420
# Dev-only fallback default. Required for /v1 auth + key management.
# Change this for any shared/non-local setup.
LITELLM_MASTER_KEY=frozenlips
UI_USERNAME=admin
UI_PASSWORD=change_me
JSON_LOGS=true

# Phoenix (local trace UI + OTLP collector)
PHOENIX_PORT=6006
PHOENIX_UI_TLS_PORT=6006
PHOENIX_OTLP_GRPC_PORT=4317
PHOENIX_WORKING_DIR=/mnt/data
# LiteLLM arize_phoenix callback -> Phoenix collector endpoint (inside compose network)
PHOENIX_COLLECTOR_HTTP_ENDPOINT=http://phoenix:6006/v1/traces
# Optional project name used by Phoenix callback traces
PHOENIX_PROJECT_NAME=litellm-proxy
PHOENIX_PROJECT_NAME_CLEAN=litellm-clean
PHOENIX_PROJECT_NAME_CHAOS=litellm-chaos
# Required for Phoenix Cloud, optional/empty for local self-hosted Phoenix
PHOENIX_API_KEY=
# App-side OTLP from dev container: https://caddy (TLS, same /certs CA as LiteLLM) or http://phoenix on backend_core
PHOENIX_COLLECTOR_ENDPOINT=https://caddy:6006/v1/traces
# Dev tracing project (compose dev service maps this to PHOENIX_PROJECT_NAME)
PHOENIX_APP_PROJECT_NAME=langgraph-course

# Ollama endpoints
OLLAMA_CONTAINER_PORT=11434
# Optional host port if Ollama is explicitly exposed via override compose file.
OLLAMA_HOST_PORT=11435
OLLAMA_HOST=http://ollama:${OLLAMA_CONTAINER_PORT}
# Toxiproxy listen ports (required before OLLAMA_API_BASE_CHAOS expansion)
TOXIPROXY_EDGE_LISTEN=11111
TOXIPROXY_OLLAMA_LISTEN=11112
OLLAMA_API_BASE_CLEAN=http://ollama:${OLLAMA_CONTAINER_PORT}
OLLAMA_API_BASE_CHAOS=http://toxiproxy:${TOXIPROXY_OLLAMA_LISTEN}
OLLAMA_DEBUG=0
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_QUEUE=2
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=1m

# Ollama model init behavior
# Default: embed + course chat floor (llama3.2:3b). Add larger models in .env if you have RAM.
OLLAMA_MODELS=nomic-embed-text:latest llama3.2:3b
# Optional additional models (example set currently used in local .env):
# OLLAMA_MODELS=nomic-embed-text:latest deepseek-coder:6.7b qwen2.5-coder:7b qwen2.5:1.5b llama3.2:3b llama3.2:1b llama3.1:8b mistral:7b mistral-nemo:12b deepseek-r1:7b
# pull: always check/pull all configured models
# pull_missing: only pull models not already present locally
# none: skip startup init, let Ollama pull on demand at first request
OLLAMA_INIT_MODE=pull_missing
OLLAMA_PULL_OPTIONS=
OLLAMA_RUN_OPTIONS=
OLLAMA_RUN_PROMPT=Say hello.
# 0 = unlimited retries, >0 = fail after N attempts per model
OLLAMA_RETRY_MAX_ATTEMPTS=0

# Optional external model provider keys (see docs/getting-started.md appendix)
GEMINI_API_KEY=
GROQ_API_KEY=

# Virtual key init behavior: required, optional, off
KEYS_INIT_MODE=required

# Dev container: LiteLLM OpenAI-compatible base URLs (Caddy TLS on dev_edge)
MODEL_BASE_URL_CLEAN=https://caddy:4000
MODEL_BASE_URL_CHAOS=https://caddy:4001

# Toxiproxy admin API (chaos channel; L6 pytest + bootstrap from dev/backend network)
TOXIPROXY_ADMIN_PORT=8474
TOXIPROXY_URL=http://toxiproxy:8474

