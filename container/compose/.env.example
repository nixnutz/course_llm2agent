# Runtime / storage
HOST_BIND_IP=127.0.0.1
HEALTHCHECK_INTERVAL=120s
# Faster probes while containers are starting (Docker healthchecks are fixed-interval; this keeps startup snappy).
HEALTHCHECK_INTERVAL_BOOT=3s
OLLAMA_DATA_DIR=./.state/ollama_data
KEYS_LOCAL_FILE=./.state/keys/keys.local.json

# Postgres (shared server, separate identities per app)
POSTGRES_PORT=5432
POSTGRES_DB_LITELLM=litellm
POSTGRES_USER_LITELLM=litellm
POSTGRES_PASSWORD_LITELLM=change_me
POSTGRES_DB_PHOENIX=phoenix
POSTGRES_USER_PHOENIX=phoenix
POSTGRES_PASSWORD_PHOENIX=change_me
DATABASE_URL=postgresql://${POSTGRES_USER_LITELLM}:${POSTGRES_PASSWORD_LITELLM}@postgres:${POSTGRES_PORT}/${POSTGRES_DB_LITELLM}

# LiteLLM proxy / UI
LITELLM_PLATFORM=linux/amd64
# Public TLS endpoint (Caddy)
LITELLM_PORT=4000
# Internal LiteLLM app port (Docker network only)
LITELLM_INTERNAL_PORT=4000
LITELLM_DEFAULT_TIMEOUT=600
# Dev-only fallback default. Required for /v1 auth + key management.
# Change this for any shared/non-local setup.
LITELLM_MASTER_KEY=frozenlips
UI_USERNAME=admin
UI_PASSWORD=change_me
JSON_LOGS=true

# Phoenix (local trace UI + OTLP collector)
PHOENIX_PORT=6006
PHOENIX_UI_TLS_PORT=6006
PHOENIX_OTLP_GRPC_PORT=4317
PHOENIX_WORKING_DIR=/mnt/data
# LiteLLM arize_phoenix callback -> Phoenix collector endpoint (inside compose network)
PHOENIX_COLLECTOR_HTTP_ENDPOINT=http://phoenix:6006/v1/traces
# Optional project name used by Phoenix callback traces
PHOENIX_PROJECT_NAME=litellm-proxy
# Required for Phoenix Cloud, optional/empty for local self-hosted Phoenix
PHOENIX_API_KEY=

# Ollama endpoints
OLLAMA_CONTAINER_PORT=11434
# Optional host port if Ollama is explicitly exposed via override compose file.
OLLAMA_HOST_PORT=11435
OLLAMA_HOST=http://ollama:${OLLAMA_CONTAINER_PORT}
OLLAMA_API_BASE=http://ollama:${OLLAMA_CONTAINER_PORT}

# Ollama model init behavior
# Keep defaults small for fast first startup.
OLLAMA_MODELS=nomic-embed-text:latest llama3.2:3b
# Optional additional models (example set currently used in local .env):
# OLLAMA_MODELS=nomic-embed-text:latest deepseek-coder:6.7b qwen2.5-coder:7b qwen2.5:1.5b llama3.2:3b llama3.2:1b llama3.1:8b mistral:7b mistral-nemo:12b
# pull: always check/pull all configured models
# pull_missing: only pull models not already present locally
# none: skip startup init, let Ollama pull on demand at first request
OLLAMA_INIT_MODE=pull_missing
OLLAMA_PULL_OPTIONS=
OLLAMA_RUN_OPTIONS=
OLLAMA_RUN_PROMPT=Say hello.
# 0 = unlimited retries, >0 = fail after N attempts per model
OLLAMA_RETRY_MAX_ATTEMPTS=0

# Optional external model provider keys
GEMINI_API_KEY=

# Virtual key init behavior: required, optional, off
KEYS_INIT_MODE=required
