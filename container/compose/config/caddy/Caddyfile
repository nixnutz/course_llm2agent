:4000 {
	tls /certs/cert.pem /certs/key.pem

	# Keep internal service topology private; terminate TLS at the edge.
	reverse_proxy litellm_clean:{$LITELLM_INTERNAL_PORT} {
		# Make external scheme/host/port explicit for upstream redirect/url generation.
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Port {server_port}
	}
}

:4001 {
	tls /certs/cert.pem /certs/key.pem

	# Dedicated chaos entrypoint for agent/dev tests.
	reverse_proxy toxiproxy:{$TOXIPROXY_EDGE_LISTEN} {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Port {server_port}
	}
}

:6006 {
	tls /certs/cert.pem /certs/key.pem

	# Expose Phoenix UI via TLS on the edge.
	reverse_proxy phoenix:6006
}
